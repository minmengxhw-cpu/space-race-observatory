{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://g2.local/schema/daily.schema.json",
  "title": "G2 DailyFile",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "focus", "items"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "focus": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    },
    "note": {
      "type": "string",
      "description": "Reader-facing footer note"
    },
    "editorNote": {
      "type": "string",
      "description": "Editor-only; must not be rendered in UI"
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "country", "domain", "title", "fact", "why", "source", "stars"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "country": { "type": "string", "enum": ["CN", "US"] },
        "domain": {
          "type": "string",
          "enum": ["ai", "aerospace", "biopharma", "future"]
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 40 },
        "fact": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "pattern": "^https?://.+"
        },
        "stars": { "type": "integer", "minimum": 1, "maximum": 3 },
        "tag": { "type": "string" },
        "pairId": { "type": "string" }
      }
    }
  }
}
