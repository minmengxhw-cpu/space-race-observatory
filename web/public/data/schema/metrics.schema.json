{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://g2.local/schema/metrics.schema.json",
  "title": "G2 MetricsFile",
  "type": "object",
  "additionalProperties": false,
  "required": ["domain", "updatedAt", "metrics"],
  "properties": {
    "domain": {
      "type": "string",
      "enum": ["ai", "aerospace", "biopharma", "future"]
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}"
    },
    "cadence": { "type": "string" },
    "subtracks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "unit", "cn", "us"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "unit": { "type": "string" },
          "cn": {
            "type": "object",
            "required": ["value", "display"],
            "properties": {
              "value": { "type": "number" },
              "display": { "type": "string" }
            }
          },
          "us": {
            "type": "object",
            "required": ["value", "display"],
            "properties": {
              "value": { "type": "number" },
              "display": { "type": "string" }
            }
          },
          "note": { "type": "string" },
          "source": { "type": "string" },
          "asOf": { "type": "string" }
        }
      }
    }
  }
}
